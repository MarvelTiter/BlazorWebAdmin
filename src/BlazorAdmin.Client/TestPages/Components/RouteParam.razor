@page "/param/{Id}"
@using Project.Constraints.Common.Attributes
@using Project.Constraints.PageHelper
@implements IRouteTagPage
@implements IDisposable
@* @attribute [TagTitle("路由参数")] *@
接收的路由参数: @Id
@code {
    [Parameter] public string? Id { get; set; }
    Guid GId => Guid.NewGuid();
    public RenderFragment GetTitle()
    {
        return $"详情-{Id}-{GId}".AsContent();
    }


    public void Dispose()
    {
        Console.WriteLine($"Id: {Id} -> Dispose");
    }

}
