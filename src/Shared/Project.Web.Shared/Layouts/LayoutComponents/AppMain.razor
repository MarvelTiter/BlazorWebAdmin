@* @if (Context != null) *@
@* { *@
@* } *@
<ScrollBar>
    <ErrorCatcher ShowMessage>
        <!-- 在路由页面中获取当前页的信息 -->
        @(ChildContent)
        @* <AuthorizeView>
            <Authorized>
            </Authorized>
            <NotAuthorized>
                未授权
            </NotAuthorized>
        </AuthorizeView> *@
    </ErrorCatcher>
</ScrollBar>

@code {
    [Inject, NotNull] IRouterStore? RouterStore { get; set; }
    [Inject, NotNull] ILogger<AppMain>? Logger { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [CascadingParameter] private RouteData? RouteData { get; set; }

    public override Task SetParametersAsync(ParameterView parameters)
    {
        if (parameters.ValueHadChanged(nameof(RouteData), RouteData, out var nrd)
         && IsRouteDataChanged(RouteData, nrd))
        {
            ChildContent = RenderWithRouteData(nrd);
            Logger.LogInformation("route data changed");
            // RouterStore.
        }
        return base.SetParametersAsync(parameters);
    }

    private static bool IsRouteDataChanged(RouteData? left, RouteData? right)
    {
        if (left is null && right is null)
        {
            return false;
        }
        else if (left is null || right is null)
        {
            return true;
        }
        else if (left.PageType != right.PageType)
        {
            return true;
        }
        else if (left.RouteValues.Count != right.RouteValues.Count)
        {
            return true;
        }
        else
        {
            foreach (var kv in left.RouteValues)
            {
                if (!right.RouteValues.ContainsKey(kv.Key) || !object.Equals(kv.Value, right.RouteValues[kv.Key]))
                {
                    return true;
                }
            }
        }

        return false;
    }

    RenderFragment? RenderWithRouteData(RouteData? routeData)
    {
        if (routeData is null)
            return ChildContent;
        return builder =>
            {
                builder.OpenComponent(0, routeData.PageType);
                foreach (var routeValue in routeData.RouteValues)
                {
                    builder.AddAttribute(1, routeValue.Key, routeValue.Value);
                }

                builder.AddComponentReferenceCapture(2, RouterStore.CollectPageAdditionalInfo);

                builder.CloseComponent();
            };
    }
}
