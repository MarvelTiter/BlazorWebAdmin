@using System.Linq
@if (!Route.HasChildren || onlyOneChildren)
{
	<MudNavLink  Href="@Route.RouteLink" Icon="@Route.IconName">
		@Route.RouteName
	</MudNavLink >
}
else
{
	<MudNavGroup Title=@Route.RouteName Icon=@Route.IconName>		
		<ChildContent>
			@foreach (var item in Route.Children)
			{
				<SideBarItem Route=item></SideBarItem>
			}
		</ChildContent>
	</MudNavGroup>
}


@code {
	[Parameter]
	public RouterMeta Route { get; set; }

	private bool onlyOneChildren => Route.Children.Count() == 1;
}
