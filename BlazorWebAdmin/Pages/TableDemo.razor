@page "/table"
@using Project.Models.Entities
<h3>Table</h3>

<MudTable Items="Users">
	<HeaderContent>
        <MudTh>用户名</MudTh>
        <MudTh>年龄</MudTh>
        <MudTh>账号</MudTh>
        <MudTh>密码</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nr">@context.UserName</MudTd>
        <MudTd DataLabel="Sign">@context.Age</MudTd>
        <MudTd DataLabel="Name">@context.UserId</MudTd>
        <MudTd DataLabel="Position">@context.Password</MudTd>
    </RowTemplate>
</MudTable>
@code {
	private List<User> Users = null;
	protected override Task OnInitializedAsync()
	{
		Users = new List<User>();
		for (var i = 0; i < 10; i++)
		{
			Users.Add(new User
				{
					UserId = $"用户ID{i + 1}",
					UserName = $"用户姓名{i + 1}",
					Age = i + 10
				});
		}
		return base.OnInitializedAsync();
	}
}
